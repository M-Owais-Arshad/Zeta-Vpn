# ZetaVPN targets Linux servers — force LF line endings for everything so shell
# scripts, systemd units and Python never end up with CRLF (which breaks
# `#!/usr/bin/env bash` on Linux) regardless of the contributor's OS.
* text=auto eol=lf

*.sh    text eol=lf
*.py    text eol=lf
*.service text eol=lf
*.conf  text eol=lf
bin/zeta text eol=lf
install.sh text eol=lf

# Treat images as binary (none tracked yet, but future-proof).
*.png binary
*.jpg binary
*.ico binary
