#!/usr/bin/env bash
# ZetaVPN privileged-action wrapper — the ONLY command the 'zetavpn' service
# user may run as root (see /etc/sudoers.d/zetavpn-panel).
#
# Modern sudo rejects wildcards in command *arguments* (only the command path
# itself may glob), so sudoers alone can't safely say "useradd with any
# username/date but nothing else". This script is what sudoers actually
# grants (with zero argument restrictions, since none are needed — a single
# fixed path); it does the argument validation itself, in one auditable
# place, before ever touching a real privileged command. Must stay root-owned
# and non-group/world-writable: if 'zetavpn' could edit this file, granting
# it "sudo to run this file" would be equivalent to full root.
set -euo pipefail

USERNAME_RE='^[a-z_][a-z0-9_-]{2,31}$'
DATE_RE='^[0-9]{4}-[0-9]{2}-[0-9]{2}$'
# Reserved/system accounts the panel must NEVER touch — mirrors the _RESERVED
# set in backend/zeta/core/ssh_manager.py. This wrapper is the REAL privilege
# boundary: the Python check runs inside the unprivileged panel and is bypassed
# by invoking this script directly (the exact contained-compromise case the
# privilege separation defends), so the denylist must be enforced HERE too —
# otherwise `root` matches USERNAME_RE and userdel/usermod/chage/pkill/chpasswd
# would all accept it.
RESERVED='root admin administrator daemon bin sys sync games man lp mail news uucp proxy www-data backup list nobody systemd-network sshd zeta zetavpn ubuntu debian'

die() { echo "zeta-privileged: $*" >&2; exit 1; }

valid_username() {
  [[ "$1" =~ $USERNAME_RE ]] || die "invalid username: $1"
  local r
  for r in $RESERVED; do
    [ "$1" = "$r" ] && die "reserved username: $1"
  done
  # MUST end with a success status: the loop's final `[ ]` test is false for a
  # valid (non-reserved) name, so without this the function returns 1 and the
  # caller's `set -e` aborts the whole wrapper BEFORE useradd/chpasswd/etc. run
  # — which surfaced as "unable to add user" for every account.
  return 0
}

valid_date_or_none() {
  # empty or "-1" (chage's "never expire") is fine; otherwise must be YYYY-MM-DD
  [ -z "$1" ] || [ "$1" = "-1" ] || [[ "$1" =~ $DATE_RE ]] || die "invalid date: $1"
}

action="${1:-}"
shift || true

case "$action" in
  useradd)
    # zeta-privileged useradd <username> [expiry-date]
    username="${1:-}"; expiry="${2:-}"
    [ -n "$username" ] || die "username required"
    valid_username "$username"
    valid_date_or_none "$expiry"
    if [ -n "$expiry" ]; then
      exec useradd -m -s /bin/false -e "$expiry" "$username"
    else
      exec useradd -m -s /bin/false "$username"
    fi
    ;;

  userdel)
    username="${1:-}"; [ -n "$username" ] || die "username required"
    valid_username "$username"
    exec userdel -r "$username"
    ;;

  usermod-lock)
    username="${1:-}"; [ -n "$username" ] || die "username required"
    valid_username "$username"
    exec usermod -L "$username"
    ;;

  usermod-unlock)
    username="${1:-}"; [ -n "$username" ] || die "username required"
    valid_username "$username"
    exec usermod -U "$username"
    ;;

  chage)
    username="${1:-}"; expiry="${2:-}"
    [ -n "$username" ] || die "username required"
    valid_username "$username"
    valid_date_or_none "$expiry"
    exec chage -E "${expiry:--1}" "$username"
    ;;

  pkill)
    username="${1:-}"; [ -n "$username" ] || die "username required"
    valid_username "$username"
    exec pkill -KILL -u "$username"
    ;;

  chpasswd)
    # zeta-privileged chpasswd <username>   (the password is read as ONE line
    # from stdin). The WRAPPER owns the target-user constraint so no stdin trick
    # can retarget root or another account — we read a single line and compose
    # "<username>:<password>" ourselves, ignoring any injected second line.
    # Refuse system accounts: valid_username's regex still matches names like
    # 'root', so also require uid >= 1000 (the panel only sets tunnel-account
    # passwords). Note: no `exec`, since a pipe is needed.
    username="${1:-}"; [ -n "$username" ] || die "username required"
    valid_username "$username"
    uid="$(id -u -- "$username" 2>/dev/null)" || die "no such user: $username"
    [ "$uid" -ge 1000 ] || die "refusing system account: $username"
    IFS= read -r password || true
    printf '%s:%s\n' "$username" "$password" | chpasswd
    ;;

  systemctl)
    subaction="${1:-}"; unit="${2:-}"
    case "$subaction" in
      restart|reload-or-restart|stop|enable|disable) ;;
      *) die "action not allowed: $subaction" ;;
    esac
    case "$unit" in
      zeta-panel|zeta-xray|zeta-singbox|zeta-ws|zeta-mtproxy|zeta-bot|zeta-badvpn|nginx|ssh|dropbear|stunnel4) ;;
      *) die "unit not allowed: $unit" ;;
    esac
    exec systemctl "$subaction" "$unit"
    ;;

  tuning)
    # Elite gaming tuning — zeta-tuning does its own snapshot/apply/exact-revert;
    # we only gate which sub-action the unprivileged panel user may trigger.
    sub="${1:-}"
    case "$sub" in apply|revert|reapply|status) ;; *) die "invalid tuning action: $sub" ;; esac
    exec /usr/local/sbin/zeta-tuning "$sub"
    ;;

  tgproxy)
    # Telegram MTProto proxy — zeta-tgproxy builds/tears-down mtg itself; we only
    # gate the verb (start downloads+builds, stop removes it, status reports).
    sub="${1:-}"
    case "$sub" in start|stop|status) ;; *) die "invalid tgproxy action: $sub" ;; esac
    exec /usr/local/sbin/zeta-tgproxy "$sub"
    ;;

  ufw-allow)
    # zeta-privileged ufw-allow <port> <tcp|udp>
    # Opens the firewall for a client-facing proxy port the admin picked in
    # the panel — without this, an inbound on a non-default port is created
    # successfully and xray/sing-box happily binds it, but stays externally
    # unreachable because nothing ever told ufw about it.
    port="${1:-}"; proto="${2:-tcp}"
    [[ "$port" =~ ^[0-9]{1,5}$ ]] && [ "$port" -ge 1 ] && [ "$port" -le 65535 ] || die "invalid port: $port"
    case "$proto" in tcp|udp) ;; *) die "invalid proto: $proto" ;; esac
    exec ufw allow "${port}/${proto}"
    ;;

  ufw-delete)
    # zeta-privileged ufw-delete <port> <tcp|udp>
    port="${1:-}"; proto="${2:-tcp}"
    [[ "$port" =~ ^[0-9]{1,5}$ ]] && [ "$port" -ge 1 ] && [ "$port" -le 65535 ] || die "invalid port: $port"
    case "$proto" in tcp|udp) ;; *) die "invalid proto: $proto" ;; esac
    exec ufw --force delete allow "${port}/${proto}"
    ;;

  killpid)
    # zeta-privileged killpid <pid> — terminate a single tunnel-session process
    # to enforce SSHAccount.max_login. Kills ONLY a pid owned by a non-system
    # user (uid >= 1000), so it can never be turned into a box-wide kill
    # primitive against root/system processes.
    pid="${1:-}"
    [[ "$pid" =~ ^[0-9]+$ ]] || die "invalid pid: $pid"
    owner_uid="$(stat -c %u "/proc/$pid" 2>/dev/null)" || die "no such pid: $pid"
    [ "$owner_uid" -ge 1000 ] || die "refusing to kill system-owned pid: $pid"
    exec kill -KILL "$pid"
    ;;

  ssh-conns)
    # Read-only: list established SSH-stack connections WITH the pids holding
    # each socket, so the panel can attribute a peer IP to its account user
    # (the app resolves pids -> users itself, unprivileged). OpenSSH holds the
    # per-connection socket in a root process, so this needs root to see the
    # owning pids. Fixed, argument-free, read-only command — safe to expose.
    exec ss -tnHp state established '( sport = :22 or sport = :109 or sport = :143 )'
    ;;

  ssh-traffic)
    # zeta-privileged ssh-traffic <uid> [uid...]
    # Per-SSH-account byte accounting (read-and-zero deltas) so the panel can show
    # each account's usage — there is no per-user stats API for raw SSH.
    #
    # We match by systemd USER SLICE (cgroup v2), NOT by uid owner: OpenSSH's
    # privilege separation keeps the client-facing connection socket owned by the
    # ROOT monitor, so `--uid-owner <account>` misses ~all tunnelled bytes (it
    # only saw session overhead — the "100MB used, 262KB shown" bug). But every
    # account gets a logind `user-<uid>.slice`, and its origin-facing tunnel
    # sockets live there, so a cgroup match on BOTH INPUT and OUTPUT captures the
    # real up+down. The chain only COUNTS (no jump target) so it can't affect
    # connectivity/ufw. (Dropbear sessions create no logind slice and aren't
    # covered — OpenSSH incl. SSH-over-WS, the common path, is.)
    CHAIN=ZETA_SSHACCT
    iptables -nL "$CHAIN" >/dev/null 2>&1 || iptables -N "$CHAIN" 2>/dev/null || true
    # Count both directions, at the TOP of each hook so ufw doesn't consume the
    # packet before our counting chain sees it. Re-assert position 1 each call.
    for HK in INPUT OUTPUT; do
      iptables -D "$HK" -j "$CHAIN" 2>/dev/null || true
      iptables -I "$HK" 1 -j "$CHAIN" 2>/dev/null || true
    done
    # 1. Emit this interval's counts (bytes = IN+OUT for each slice) BEFORE the
    #    rebuild below resets them.
    iptables -nvxL "$CHAIN" 2>/dev/null | awk '/user-[0-9]+\.slice/ {
        for (i=1;i<=NF;i++) if ($i ~ /user-[0-9]+\.slice/) { u=$i; gsub(/[^0-9]/,"",u); print u, $2 } }' || true
    # 2. Rebuild the per-slice rules FRESH each call. A `cgroup --path` rule pins
    #    the cgroup at insert time, so when a user disconnects+reconnects (the
    #    slice is destroyed and recreated with a new id) a kept rule silently
    #    counts 0 — the "shows 0 after reconnect" bug. Flush + re-add for the
    #    currently-online uids keeps every counter bound to the LIVE slice and
    #    zeroes it for the next interval. (Flushing rules leaves the hook jumps.)
    iptables -F "$CHAIN" 2>/dev/null || true
    for u in "$@"; do
      [[ "$u" =~ ^[0-9]+$ ]] || continue
      slice="user.slice/user-${u}.slice"
      # A --path to a missing cgroup is rejected; only account accounts that have
      # a live logind session (their slice exists). Offline => no traffic anyway.
      [ -d "/sys/fs/cgroup/${slice}" ] && { iptables -A "$CHAIN" -m cgroup --path "$slice" 2>/dev/null || true; }
    done
    ;;

  *)
    die "unknown action: $action"
    ;;
esac
