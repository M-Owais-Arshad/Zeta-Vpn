#!/usr/bin/env bash
# ZetaVPN command-line manager. Run `zeta` for the interactive menu, or use a
# subcommand: status | restart | info | passwd | update | backup | expire-check | uninstall
set -euo pipefail

ZETA_HOME="${ZETA_HOME:-/opt/zetavpn}"
if [ -f "${ZETA_HOME}/scripts/common.sh" ]; then
  # shellcheck disable=SC1091
  . "${ZETA_HOME}/scripts/common.sh"
else
  C_RESET='\033[0m'; C_CYN='\033[36m'; C_GRN='\033[32m'; C_YEL='\033[33m'; C_RED='\033[31m'; C_BOLD='\033[1m'
  msg(){ printf "${C_CYN}::${C_RESET} %s\n" "$*"; }; ok(){ printf "${C_GRN} ✓${C_RESET} %s\n" "$*"; }
  warn(){ printf "${C_YEL} !${C_RESET} %s\n" "$*"; }; err(){ printf "${C_RED} ✗${C_RESET} %s\n" "$*" >&2; }
  die(){ err "$*"; exit 1; }
fi

UNITS=(zeta-panel zeta-xray zeta-singbox zeta-ws nginx ssh dropbear stunnel4)

cmd_status() {
  printf "\n${C_BOLD}ZetaVPN services${C_RESET}\n"
  for u in "${UNITS[@]}"; do
    if systemctl list-unit-files 2>/dev/null | grep -q "^${u}.service\|^${u}@"; then
      state="$(systemctl is-active "$u" 2>/dev/null || echo inactive)"
      if [ "$state" = "active" ]; then printf "  ${C_GRN}●${C_RESET} %-14s %s\n" "$u" "$state"
      else printf "  ${C_RED}○${C_RESET} %-14s %s\n" "$u" "$state"; fi
    fi
  done
  printf "\n"
}

cmd_restart() {
  local target="${1:-all}"
  if [ "$target" = "all" ]; then
    msg "Restarting all ZetaVPN services"
    for u in zeta-panel zeta-xray zeta-singbox zeta-ws nginx; do systemctl restart "$u" 2>/dev/null || true; done
  else
    systemctl restart "$target" && ok "restarted $target"
  fi
}

cmd_info() {
  local env="${ZETA_HOME}/.env"
  if [ ! -r "$env" ]; then
    warn "Can't read ${env} (root-owned). Run:  sudo zeta info"
    return 0
  fi
  local base port addr dom user host scheme
  base="$(sed -n 's/^ZETA_WEB_BASE_PATH=//p' "$env" | tail -1)"
  port="$(sed -n 's/^ZETA_PORT=//p' "$env" | tail -1)"
  addr="$(sed -n 's/^ZETA_SERVER_ADDRESS=//p' "$env" | tail -1)"
  dom="$(sed -n 's/^ZETA_SERVER_DOMAIN=//p' "$env" | tail -1)"
  user="$(sed -n 's/^ZETA_ADMIN_USERNAME=//p' "$env" | tail -1)"
  host="${dom:-${addr:-<server-ip>}}"; scheme="http"; [ -n "$dom" ] && scheme="https"
  printf "\n  ${C_BOLD}ZetaVPN panel${C_RESET}\n"
  printf "  ────────────────────────────────────────────\n"
  printf "  Panel URL : %s://%s/%s/\n" "$scheme" "$host" "$base"
  printf "  Username  : %s\n" "${user:-admin}"
  printf "  Password  : ${C_YEL}stored as a bcrypt hash only${C_RESET} (shown once at install)\n"
  printf "              lost it?  ${C_BOLD}sudo zeta passwd${C_RESET}  to set a new one\n"
  printf "  SSH ports : 22 · 109/143 (dropbear) · 445 (SSL) · 8880 (WS)\n"
  printf "  Config    : %s\n" "$env"
  printf "  ────────────────────────────────────────────\n\n"
  [ -f "${ZETA_HOME}/data/initial_admin.txt" ] && { echo "  First-run credentials file:"; sed 's/^/    /' "${ZETA_HOME}/data/initial_admin.txt"; echo; }
}

cmd_passwd() {
  # The ONLY panel-password recovery path: the password is stored as a bcrypt
  # hash (never plaintext) and shown just once at install, so a lost password
  # would otherwise mean a total lockout. This hashes a new one with the app's
  # own bcrypt and writes it to the DB, bumping token_version to log out any
  # existing session.
  [ "$(id -u)" -eq 0 ] || die "Run as root:  sudo zeta passwd"
  local user; user="$(sed -n 's/^ZETA_ADMIN_USERNAME=//p' "${ZETA_HOME}/.env" 2>/dev/null | tail -1)"
  user="${user:-admin}"
  local p1 p2
  read -rsp "New panel password for '$user': " p1; echo
  read -rsp "Retype new password:            " p2; echo
  [ -n "$p1" ] || die "Password must not be empty."
  [ "${#p1}" -ge 8 ] || die "Use at least 8 characters."
  [ "$p1" = "$p2" ] || die "Passwords don't match."
  # Pipe the password via stdin so it never lands in the process list or history;
  # run as the panel's own user so the DB (+ any WAL files) stay zetavpn-owned.
  if printf '%s' "$p1" | sudo -u zetavpn ZETA_HOME="$ZETA_HOME" "${ZETA_HOME}/venv/bin/python" -c '
import sys, os
sys.path.insert(0, os.path.join(os.environ.get("ZETA_HOME", "/opt/zetavpn"), "backend"))
pw = sys.stdin.read()
target = sys.argv[1]
from zeta.db import SessionLocal
from zeta.models import User
from zeta.auth import hash_password
db = SessionLocal()
u = (db.query(User).filter(User.username == target).first()
     or db.query(User).filter(User.role == "admin").order_by(User.id.asc()).first()
     or db.query(User).order_by(User.id.asc()).first())
if u is None:
    sys.exit("no panel user found in the database")
u.password_hash = hash_password(pw)
u.token_version = (u.token_version or 0) + 1
db.commit()
print(u.username)
' "$user"; then
    ok "Panel password updated — existing sessions logged out. Sign in with the new one."
  else
    die "Password reset failed (is the panel installed and the DB present?)."
  fi
}

cmd_update() {
  [ "$(id -u)" -eq 0 ] || die "Run as root (sudo zeta update)."
  local full=0
  [ "${1:-}" = "--full" ] && full=1
  local data="${ZETA_DATA:-${ZETA_HOME}/data}" env="${ZETA_ENV:-${ZETA_HOME}/.env}"

  # 1. Safety backup. The DB + secrets are gitignored so git never touches them,
  #    but a fresh pre-update copy is cheap insurance so an update can NEVER lose
  #    an operator's accounts/settings (single most-recent copy, replaced each run).
  local bdir="/var/backups/zetavpn/pre-update"
  mkdir -p "$bdir"
  # rm the previous copy first: `cp -a SRC $bdir/data` into an existing dir would
  # nest ($bdir/data/data/...) each run, burying the newest snapshot.
  rm -rf "$bdir/data"
  cp -a "$data" "$bdir/data" 2>/dev/null || true
  cp "$env" "$bdir/env" 2>/dev/null || true

  # 2. Fetch the latest release. reset --hard (not pull) so a diverged / locally
  #    edited checkout can't block the update; data/ and .env are gitignored and
  #    survive untouched — no user data is ever deleted.
  local old_rev="" new_rev="" branch="${ZETA_BRANCH:-main}"
  local repo="${ZETA_REPO:-https://github.com/M-Owais-Arshad/Zeta-Vpn.git}"
  if [ -d "${ZETA_HOME}/.git" ]; then
    # Fetch from the public HTTPS URL explicitly (origin may be an SSH remote the
    # box has no key for) and reset to it. `-c safe.directory` avoids git's
    # "dubious ownership" refusal when run as root over a zetavpn-owned checkout.
    local -a G=(git -c "safe.directory=${ZETA_HOME}" -C "$ZETA_HOME")
    old_rev="$("${G[@]}" rev-parse --short HEAD 2>/dev/null || echo none)"
    if "${G[@]}" fetch --depth 1 "$repo" "$branch" 2>/dev/null \
       && "${G[@]}" reset --hard FETCH_HEAD >/dev/null 2>&1; then
      new_rev="$("${G[@]}" rev-parse --short HEAD)"
      [ "$old_rev" = "$new_rev" ] && [ "$full" = 0 ] && { ok "Already up to date (${new_rev})."; return 0; }
      msg "Source ${old_rev} -> ${new_rev}"
    else
      warn "git fetch/reset failed — leaving the current source in place"
    fi
  else
    warn "Not a git checkout — refreshing deps/helpers from the current source only."
  fi
  chmod +x "${ZETA_HOME}/scripts/"*.sh "${ZETA_HOME}/bin/zeta" 2>/dev/null || true

  # --full: re-run the installer (the supported re-entry point — it keeps .env +
  #  the DB, re-applies firewall / SSH stack / nginx / tuning, and restarts the
  #  cores). Use this after a release that changes system config; users briefly
  #  reconnect.
  if [ "$full" = 1 ]; then
    warn "Full update: re-applying system config (firewall/SSH/nginx) — users reconnect"
    ZETA_YES=1 bash "${ZETA_HOME}/install.sh" --yes
    # install.sh only `enable --now`s the panel, which is a NO-OP for an already-
    # running service — so on a --full update the OLD panel process keeps running
    # against a not-yet-migrated schema (new DB columns never get added, new code
    # never loads). Restart it explicitly, exactly like the panel-only path below.
    systemctl daemon-reload 2>/dev/null || true
    systemctl restart zeta-panel 2>/dev/null || true
    ok "Full update complete${new_rev:+ ($new_rev)} — panel reloaded"
    return 0
  fi

  # 3. Python deps (may have changed between releases).
  "${ZETA_HOME}/venv/bin/pip" install --quiet -r "${ZETA_HOME}/backend/requirements.txt" 2>/dev/null \
    || warn "pip step reported problems"

  # 4. Re-install the pieces that live OUTSIDE ZETA_HOME (the root helpers + CLI)
  #    so a fix to them actually lands. daemon-reload picks up unit changes
  #    without restarting the running data-plane units.
  install -m 0755 -o root -g root "${ZETA_HOME}/scripts/zeta-privileged" /usr/local/sbin/zeta-privileged 2>/dev/null || true
  install -m 0755 -o root -g root "${ZETA_HOME}/scripts/zeta-tuning.sh"   /usr/local/sbin/zeta-tuning     2>/dev/null || true
  install -m 0755 -o root -g root "${ZETA_HOME}/scripts/zeta-tgproxy.sh"  /usr/local/sbin/zeta-tgproxy    2>/dev/null || true
  install -m 0755 "${ZETA_HOME}/bin/zeta" /usr/local/bin/zeta 2>/dev/null || true
  local ws_port=8880
  [ -f "$env" ] && ws_port="$(sed -n 's/^ZETA_WS_PORT=//p' "$env" | tail -1)"
  ws_port="${ws_port:-8880}"
  local tmp_units; tmp_units="$(mktemp -d)"
  for f in "${ZETA_HOME}/systemd/"zeta-*.service; do
    sed -e "s#/opt/zetavpn#${ZETA_HOME}#g" -e "s#--listen 0.0.0.0:8880#--listen 0.0.0.0:${ws_port}#" \
      "$f" > "${tmp_units}/$(basename "$f")"
  done
  install -m 0644 "${tmp_units}/"zeta-*.service /etc/systemd/system/ 2>/dev/null || true
  rm -rf "$tmp_units"
  systemctl daemon-reload

  # 5. Restart ONLY the panel (control plane). This reloads the new code + runs
  #    additive DB migrations WITHOUT dropping a single tunnel: the proxy cores
  #    (xray/sing-box) and the whole SSH stack keep running. The panel re-applies
  #    a core config only when it actually changes (apply() is a no-op otherwise),
  #    so live users stay connected across the update — the whole point.
  systemctl restart zeta-panel
  ok "Update complete${new_rev:+ ($new_rev)} — panel reloaded, live tunnels kept."
  msg "If this release changed the firewall / SSH stack / nginx, run 'sudo zeta update --full' to apply those (brief reconnect)."
}

cmd_backup() {
  local out="${1:-/root/zeta-backup-$(date +%Y%m%d-%H%M%S).tar.gz}"
  tar -czf "$out" -C "$ZETA_HOME" data .env 2>/dev/null && ok "Backup written to $out"
}

cmd_expire_check() {
  # OS enforces login expiry via `chage -E`; here we also kill live sessions of
  # any account whose expiry has passed.
  local now exp exp_epoch
  now="$(date +%s)"
  for u in $(awk -F: '$3>=1000 && $3<65534 {print $1}' /etc/passwd); do
    exp="$(chage -l "$u" 2>/dev/null | awk -F: '/Account expires/ {sub(/^[ \t]+/,"",$2); print $2}')"
    [ -z "$exp" ] || [ "$exp" = "never" ] && continue
    exp_epoch="$(date -d "$exp" +%s 2>/dev/null)" || continue
    if [ "$exp_epoch" -lt "$now" ]; then
      usermod -L "$u" 2>/dev/null || true
      pkill -KILL -u "$u" 2>/dev/null || true
    fi
  done
}

cmd_ssh_create() {
  read -rp "Username: " u
  if ! [[ "$u" =~ ^[a-z_][a-z0-9_-]{2,31}$ ]]; then
    err "Username must be 3-32 chars, lowercase letters/digits/_/-, starting with a letter or underscore."
    return 1
  fi
  case "$u" in
    root|admin|administrator|daemon|bin|sys|sync|games|man|lp|mail|news|uucp|proxy|www-data|backup|list|nobody|systemd-network|sshd|zeta|ubuntu|debian)
      err "'$u' is a reserved username."; return 1 ;;
  esac
  read -rsp "Password: " p; echo
  if [ -z "$p" ]; then
    err "Password must not be empty."
    return 1
  fi
  read -rp "Days valid [30]: " d; d="${d:-30}"
  local exp; exp="$(date -d "+${d} days" +%Y-%m-%d)"
  useradd -m -s /bin/false -e "$exp" "$u" && echo "${u}:${p}" | chpasswd \
    && ok "Created SSH account '$u' (expires $exp)" || err "Failed to create account"
  warn "Tip: create accounts from the panel to track them there too."
}

cmd_uninstall() { bash "${ZETA_HOME}/scripts/uninstall.sh"; }

menu() {
  while true; do
    clear
    command -v banner >/dev/null 2>&1 && banner
    cmd_status
    cat <<MENU
  ${C_BOLD}ZetaVPN manager${C_RESET}
    1) Restart a service        6) Backup data + config
    2) Restart everything       7) Create SSH account (quick)
    3) Panel info / credentials 8) Reset panel password
    4) Live panel logs          9) Uninstall
    5) Update ZetaVPN           0) Exit
MENU
    read -rp "  Choose: " c
    case "$c" in
      1) read -rp "  Service name: " s; cmd_restart "$s"; read -rp "  [enter]" _ ;;
      2) cmd_restart all; read -rp "  [enter]" _ ;;
      3) cmd_info; read -rp "  [enter]" _ ;;
      4) journalctl -u zeta-panel -n 60 -f ;;
      5) cmd_update; read -rp "  [enter]" _ ;;
      6) cmd_backup; read -rp "  [enter]" _ ;;
      7) cmd_ssh_create; read -rp "  [enter]" _ ;;
      8) cmd_passwd; read -rp "  [enter]" _ ;;
      9) cmd_uninstall; exit 0 ;;
      0) exit 0 ;;
      *) ;;
    esac
  done
}

case "${1:-menu}" in
  menu|"")        menu ;;
  status)         cmd_status ;;
  restart)        cmd_restart "${2:-all}" ;;
  info)           cmd_info ;;
  passwd)         cmd_passwd ;;
  update)         cmd_update "${2:-}" ;;
  backup)         cmd_backup "${2:-}" ;;
  expire-check)   cmd_expire_check ;;
  uninstall)      cmd_uninstall ;;
  *) echo "Usage: zeta {menu|status|restart [unit]|info|passwd|update|backup|expire-check|uninstall}" ;;
esac
